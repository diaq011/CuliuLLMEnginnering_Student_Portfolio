#!/usr/bin/env bash
# Copy this file to run.local.sh (which is gitignored) and fill in your real key:
#   cp run.local.sh.example run.local.sh && chmod +x run.local.sh && ./run.local.sh
# Never commit run.local.sh with a real DEEPSEEK_API_KEY.
set -euo pipefail

export DEEPSEEK_API_KEY="sk-your-deepseek-key-here"
export DEEPSEEK_API_URL="${DEEPSEEK_API_URL:-https://api.deepseek.com/v1}"
export DEEPSEEK_MODEL="${DEEPSEEK_MODEL:-deepseek-chat}"

# macOS often occupies :5000 with the AirPlay receiver, so default to 5001.
export APP_PORT="${APP_PORT:-5001}"

cd "$(dirname "$0")"
exec python3 app.py
